{
    "version": 2,
    "routes": [
        {
            "src": "/api/video-stream/(?<videoId>[^/]+)",
            "dest": "/api/video-stream?videoId=$videoId"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}