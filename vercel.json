{
    "builds": [
        {
            "src": "index.html",
            "use": "@vercel/static"
        },
        {
            "src": "api/video-stream.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/video-stream/(?<videoId>[^/]+)",
            "dest": "/api/video-stream.js?videoId=$videoId"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}