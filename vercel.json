{
    "builds": [
        {
            "src": "index.html",
            "use": "@vercel/static"
        },
        {
            "src": "api/video-stream.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/video-stream",
            "dest": "/api/video-stream.js"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}
